# Firebase config (contains sensitive project keys)
# Exclude google-services.json files by default
**/google-services.json
# But allow root project config and debug/release variants to be tracked
!/google-services.json
!**/src/debug/google-services.json
!**/src/release/google-services.json

# But allow example env files to be tracked
!.env.example
!.env.staging.example
!.env.production.example

